{
    "manifest_version": 2,

    "name": "sidebar notepad",
    "description": "notepad",
    "version": "1.0",
    "background": {"scripts": ["background.js"]},
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    
    "permissions": [
        "scripting"

    ],

    "sidebar_action": {
        "default_icon": "icon.png",
        "default_panel": "panel.html",
        "default_title": "notepad"
    }
    
}